---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  collection: string;
  year?: number;
  slug: string;
  image: ImageMetadata;
  status?: string;
  delay?: number;
  loading?: 'lazy' | 'eager';
}

const {
  title,
  collection,
  year,
  slug,
  image,
  status = 'available',
  delay = 0,
  loading = 'lazy',
} = Astro.props;

const collectionLabel = collection.replace(/-/g, ' ');
---

<a
  href={`/work/${slug}`}
  class:list={['card', 'reveal', delay > 0 && `reveal-d${delay}`]}
  aria-label={title}
>
  <div class="card-media">
    <Image
      src={image}
      alt={title}
      width={800}
      height={533}
      class="card-img"
      loading={loading}
    />
    <div class="card-vignette" aria-hidden="true"></div>
    {status === 'sold' && <span class="card-badge t-eyebrow">Sold</span>}
  </div>
  <div class="card-info" aria-hidden="true">
    <p class="card-title t-h3">{title}</p>
    <p class="card-meta t-caption">
      {collectionLabel}{year ? ` · ${year}` : ''}
    </p>
  </div>
</a>

<style>
  .card { display: block; }

  /* ── Image ───────────────────────────────── */
  .card-media {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--color-bg-elevated);
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms ease-out;
  }

  .card-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 55%, rgba(0, 0, 0, 0.5) 100%);
    opacity: 0;
    pointer-events: none;
    transition: opacity 600ms ease-out;
  }

  .card-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background: var(--color-bg);
    color: var(--color-fg-muted);
    padding: 4px 10px;
    border: 1px solid var(--color-line);
  }

  /* ── Info (hover-reveal) ─────────────────── */
  .card-info {
    padding-top: 16px;
    display: grid;
    gap: 4px;
  }

  .card-title {
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.35s ease-out, transform 0.35s ease-out;
  }

  .card-meta {
    opacity: 0;
    transition: opacity 0.35s ease-out 0.04s;
    text-transform: capitalize;
  }

  /* ── Hover ───────────────────────────────── */
  .card:hover .card-img      { transform: scale(1.02); }
  .card:hover .card-vignette { opacity: 1; }
  .card:hover .card-title    { opacity: 1; transform: translateY(0); }
  .card:hover .card-meta     { opacity: 1; }

  /* Always visible on touch devices */
  @media (hover: none) {
    .card-title,
    .card-meta { opacity: 1; transform: none; }
  }
</style>
