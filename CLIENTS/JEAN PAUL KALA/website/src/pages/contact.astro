---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const piece = Astro.url.searchParams.get('piece') ?? '';
---

<BaseLayout
  title="Contact"
  description="Inquire about a sculpture, commission, or exhibition by Jean-Paul Kala."
>
  <Navigation slot="nav" />

  <section class="contact-hero section">
    <div class="wrap--wide">
      <p class="t-eyebrow reveal" style="margin-bottom: 24px;">Get in touch</p>
      <h1 class="t-display reveal reveal-d1">Contact.</h1>
    </div>
  </section>

  <div class="wrap--wide contact-body">
    <form
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="contact-form reveal"
    >
      <input type="hidden" name="form-name" value="contact" />
      <p hidden><input name="bot-field" /></p>

      <div class="form-row-2">
        <div class="form-field">
          <label for="name" class="t-eyebrow form-label">Name</label>
          <input type="text" id="name" name="name" class="form-input" required placeholder="Your name" />
        </div>
        <div class="form-field">
          <label for="email" class="t-eyebrow form-label">Email</label>
          <input type="email" id="email" name="email" class="form-input" required placeholder="your@email.com" />
        </div>
      </div>

      <div class="form-field">
        <label for="subject" class="t-eyebrow form-label">Subject</label>
        <input
          type="text"
          id="subject"
          name="subject"
          class="form-input"
          placeholder="Inquiry, commission, exhibition…"
          value={piece ? `Inquiry about: ${piece}` : ''}
        />
      </div>

      <div class="form-field">
        <label for="message" class="t-eyebrow form-label">Message</label>
        <textarea
          id="message"
          name="message"
          class="form-input form-textarea"
          required
          rows="6"
          placeholder="Tell me about your project or interest…"
        ></textarea>
      </div>

      <button type="submit" class="form-submit t-eyebrow">Send message →</button>
    </form>

    <aside class="contact-info reveal reveal-d2">
      <div class="info-block">
        <p class="t-eyebrow info-label">Studio</p>
        <p class="t-body">Brussels, Belgium</p>
      </div>
      <div class="info-block">
        <p class="t-eyebrow info-label">Email</p>
        <a href="mailto:info@jeanpaulkala.com" class="link-arrow" style="font-size: 14px;">
          info@jeanpaulkala.com <span class="arrow">→</span>
        </a>
      </div>
      <div class="info-block">
        <p class="t-eyebrow info-label">Phone</p>
        <p class="t-body">+(32) 483.051.861</p>
      </div>
      <div class="info-block">
        <p class="t-eyebrow info-label">Exhibited in</p>
        <p class="t-body" style="line-height: 1.8;">
          Brussels · Paris<br />Cannes · Dubai<br />Courchevel
        </p>
      </div>
    </aside>
  </div>

  <div style="height: 128px;"></div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .contact-hero {
    padding-top: calc(var(--nav-h) + 96px);
    padding-bottom: 64px;
  }

  .contact-body {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: clamp(48px, 6vw, 96px);
    align-items: start;
  }

  /* FORM */
  .contact-form { display: grid; gap: 24px; }

  .form-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-field { display: flex; flex-direction: column; gap: 10px; }

  .form-label { display: block; }

  .form-input {
    font-family: var(--font);
    font-size: 15px;
    font-weight: 400;
    color: var(--color-fg);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-line);
    padding: 14px 16px;
    outline: none;
    transition: border-color 0.2s ease;
    resize: vertical;
    border-radius: 0;
    appearance: none;
  }

  .form-input::placeholder { color: var(--color-fg-muted); opacity: 0.5; }

  .form-input:focus { border-color: var(--color-fg-muted); }

  .form-textarea { min-height: 144px; }

  .form-submit {
    justify-self: start;
    background: none;
    border: none;
    color: var(--color-accent);
    font-size: 13px;
    border-bottom: 1px solid var(--color-accent);
    padding-bottom: 2px;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .form-submit:hover { opacity: 0.7; }

  /* INFO */
  .contact-info { display: grid; gap: 0; }

  .info-block {
    border-top: 1px solid var(--color-line);
    padding-block: 24px;
    display: grid;
    gap: 8px;
  }

  .info-label { margin-bottom: 4px; }

  @media (max-width: 1023px) {
    .contact-body { grid-template-columns: 1fr; }
    .contact-info {
      border-top: 1px solid var(--color-line);
      padding-top: 48px;
      grid-template-columns: repeat(2, 1fr);
    }
    .info-block { border-top: none; padding-top: 0; }
  }

  @media (max-width: 599px) {
    .form-row-2 { grid-template-columns: 1fr; }
    .contact-info { grid-template-columns: 1fr; }
    .info-block {
      border-top: 1px solid var(--color-line);
      padding-top: 24px;
    }
  }
</style>
