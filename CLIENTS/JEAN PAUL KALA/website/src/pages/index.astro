---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const all = await getCollection('artworks');
const artworks = [...all].sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));
const total = artworks.length;
---

<BaseLayout title="Jean-Paul Kala">
  <Navigation slot="nav" />

  <!-- ── VERTICAL SHOWCASE ────────────────────────────── -->
  <div class="showcase" id="showcase">
    {artworks.map((a, i) => (
      <article class="piece" data-index={i}>
        <a href={`/work/${a.id}`} class="piece-link" aria-label={`View ${a.data.title}`}>
          <div class="piece-media">
            <Image
              src={a.data.image}
              alt={`${a.data.title} — ${a.data.collection.replace(/-/g,' ')} by Jean-Paul Kala`}
              width={2400}
              height={1600}
              class="piece-img"
              loading={i < 2 ? 'eager' : 'lazy'}
            />
          </div>
          <div class="piece-gradient" aria-hidden="true"></div>
          <div class="piece-info" aria-hidden="true">
            <div class="piece-info-left">
              <p class="piece-eyebrow t-eyebrow">
                {a.data.collection.replace(/-/g,' ')}{a.data.year ? ` · ${a.data.year}` : ''}
              </p>
              <h2 class="piece-name">{a.data.title}</h2>
            </div>
            <span class="piece-arrow" aria-hidden="true">→</span>
          </div>
        </a>
        <div class="piece-counter t-eyebrow" aria-hidden="true">
          {String(i + 1).padStart(2, '0')} / {String(total).padStart(2, '0')}
        </div>
      </article>
    ))}
  </div>

  <!-- ── FULL GALLERY ──────────────────────────────────── -->
  <section class="all-gallery" id="gallery" aria-label="All works">
    <div class="gallery-bar">
      <span class="t-eyebrow">All works · {total} pieces</span>
      <a href="/work" class="t-eyebrow gallery-bar-link">Browse by collection →</a>
    </div>
    <div class="all-gallery-grid">
      {artworks.map((a) => (
        <a href={`/work/${a.id}`} class="ag-item" aria-label={a.data.title}>
          <Image
            src={a.data.image}
            alt={a.data.title}
            width={700}
            height={700}
            class="ag-img"
            loading="lazy"
          />
          <div class="ag-overlay" aria-hidden="true">
            <span class="t-caption ag-title">{a.data.title}</span>
            {a.data.year && <span class="t-caption ag-year">{a.data.year}</span>}
          </div>
        </a>
      ))}
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ── SHOWCASE ──────────────────────────────────────── */
  .showcase {
    width: 100%;
  }

  .piece {
    position: relative;
    height: 100svh;
    overflow: hidden;
  }

  .piece-link {
    display: block;
    height: 100%;
    position: relative;
  }

  .piece-media {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .piece-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 120%;
    top: -10%;
    object-fit: cover;
    object-position: center;
    will-change: transform;
    transition: transform 0.1s linear;
  }

  .piece-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10, 10, 10, 0.75) 0%,
      rgba(10, 10, 10, 0.15) 50%,
      transparent 100%
    );
    pointer-events: none;
  }

  .piece-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 36px var(--pad-x);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
  }

  .piece-eyebrow {
    color: rgba(245, 245, 242, 0.55);
    margin-bottom: 10px;
    text-transform: capitalize;
  }

  .piece-name {
    font-size: clamp(26px, 3.5vw, 52px);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--color-fg);
  }

  .piece-arrow {
    font-size: 28px;
    color: var(--color-fg);
    opacity: 0;
    transform: translateX(-10px);
    transition: opacity 0.25s ease-out, transform 0.25s ease-out;
    flex-shrink: 0;
    padding-bottom: 4px;
  }

  .piece-link:hover .piece-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .piece-counter {
    position: absolute;
    top: calc(var(--nav-h) + 20px);
    right: var(--pad-x);
    color: rgba(245, 245, 242, 0.35);
    letter-spacing: 0.1em;
  }

  /* ── FULL GALLERY ──────────────────────────────────── */
  .all-gallery {
    background: var(--color-bg);
  }

  .gallery-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px var(--pad-x);
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }

  .gallery-bar-link {
    color: var(--color-fg-muted);
    transition: color 0.2s ease-out;
  }

  .gallery-bar-link:hover {
    color: var(--color-fg);
  }

  .all-gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    background: var(--color-line);
  }

  .ag-item {
    position: relative;
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--color-bg-elevated);
  }

  .ag-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease-out;
  }

  .ag-item:hover .ag-img {
    transform: scale(1.04);
  }

  .ag-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 10, 0.65);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 14px 16px;
    opacity: 0;
    transition: opacity 0.25s ease-out;
  }

  .ag-item:hover .ag-overlay {
    opacity: 1;
  }

  .ag-title {
    color: var(--color-fg);
  }

  .ag-year {
    color: var(--color-fg-muted);
    margin-top: 2px;
  }

  /* Always visible on touch */
  @media (hover: none) {
    .ag-overlay { opacity: 1; }
    .piece-arrow { opacity: 1; transform: translateX(0); }
  }

  /* ── RESPONSIVE ─────────────────────────────────────── */
  @media (max-width: 1199px) {
    .all-gallery-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 767px) {
    .all-gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .piece-name { font-size: clamp(22px, 6vw, 36px); }
    .piece-info { padding: 28px 20px; }
    .piece-counter { right: 20px; }
    .gallery-bar { padding: 14px 20px; }
  }

  @media (max-width: 479px) {
    .all-gallery-grid { grid-template-columns: repeat(2, 1fr); gap: 1px; }
  }
</style>

<script>
  // Subtle parallax on showcase images
  const pieces = document.querySelectorAll<HTMLElement>('.piece');

  function updateParallax() {
    const vh = window.innerHeight;
    pieces.forEach((piece) => {
      const rect = piece.getBoundingClientRect();
      if (rect.bottom < -200 || rect.top > vh + 200) return;
      // progress: 1 when just entering from below, 0 at center, -1 when leaving at top
      const progress = rect.top / vh;
      const img = piece.querySelector<HTMLElement>('.piece-img');
      if (img) {
        img.style.transform = `translateY(${progress * 7}%)`;
      }
    });
  }

  window.addEventListener('scroll', updateParallax, { passive: true });
  updateParallax();
</script>
